# video-vision-mcp configuration.
# Copy this file to `.env` (cp env.example .env) and fill in what you need.
# NOTHING is required for tier 1 (local, free).

# --- Backend keys (all optional). Precedence: Gemini > OpenAI > Groq > local. ---
# Tier 2 — cloud ASR (better transcription quality / accents):
OPENAI_API_KEY=
GROQ_API_KEY=
# Tier 3 — native Gemini video understanding (default when set):
GEMINI_API_KEY=
# GOOGLE_API_KEY is accepted as an alias for GEMINI_API_KEY.

# --- Tier 3 control ---
# Force tiers 1/2 even when a Gemini key is present:
VIDEO_MCP_DISABLE_GEMINI=false
VIDEO_MCP_GEMINI_MODEL=gemini-2.5-flash

# --- Tier 1 local whisper.cpp ---
VIDEO_MCP_WHISPER_MODEL=base
# Optional explicit ggml model path (otherwise auto-downloaded to the cache):
# VIDEO_MCP_WHISPER_MODEL_PATH=/abs/path/ggml-base.bin

# --- Frame extraction ---
# Seconds between sampled frames (default 1.0 = one per second). Denser: 0.5/0.25/0.1; sparser: 2/5.
VIDEO_MCP_FRAME_INTERVAL_SEC=1.0
# Safety cap on total frames (protects context on long/dense videos):
VIDEO_MCP_MAX_FRAMES=60
VIDEO_MCP_FRAME_MAX_PX=1024

# --- Cache (defaults to ~/.cache/video-vision-mcp) ---
# VIDEO_MCP_CACHE_DIR=~/.cache/video-vision-mcp
