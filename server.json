{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.KitDevUA/video-vision-mcp",
  "description": "Analyze any video (local file or URL) into frames + transcript for Claude Code",
  "version": "0.3.0",
  "repository": {
    "url": "https://github.com/KitDevUA/video-vision-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "video-vision-mcp",
      "version": "0.3.0",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "VIDEO_MCP_ENV",
          "description": "Optional path to a .env file with config (API keys, tuning).",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "GEMINI_API_KEY",
          "description": "Enables tier-3 native Gemini video analysis (default when set).",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "OPENAI_API_KEY",
          "description": "Enables tier-2 OpenAI Whisper transcription.",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "GROQ_API_KEY",
          "description": "Enables tier-2 Groq whisper-large-v3 transcription.",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ]
}
